<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MeltdownMonitor.Mobile.ViewModels"
             x:Class="MeltdownMonitor.Mobile.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="20">

            <StackPanel Spacing="6">
                <TextBlock Text="Device" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding DeviceTypes}"
                          SelectedItem="{Binding DeviceType, Mode=TwoWay}"
                          HorizontalAlignment="Stretch" />
                <TextBlock Text="Auto connects to the first heart-rate device found."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Alerts" FontWeight="SemiBold" />
                <CheckBox Content="Sound chime when alerting"
                          IsChecked="{Binding EnableChime, Mode=TwoWay}" />
                <CheckBox Content="Show notifications"
                          IsChecked="{Binding EnableNotifications, Mode=TwoWay}" />
                <Button Content="Request notification permission"
                        Command="{Binding RequestNotificationsCommand}" />
                <TextBlock Text="Suggestion shown in alerts:" FontSize="12" Foreground="#8A8F98" />
                <TextBox Text="{Binding AlertSuggestion, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Display" FontWeight="SemiBold" />
                <CheckBox Content="Show Live Activity"
                          IsChecked="{Binding EnableLiveActivity, Mode=TwoWay}" />
                <TextBlock Text="Shows current state, heart rate, and balance on the Lock Screen and Dynamic Island."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Regulation field" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Comet trail length" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RegulationTrailLength, StringFormat='{}{0} pts'}" />
                </Grid>
                <Slider Minimum="12" Maximum="2160"
                        Value="{Binding RegulationTrailLength, Mode=TwoWay}" />
                <TextBlock Text="How many recent readings the comet trail shows."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Jitter exaggeration" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding JitterExaggeration, StringFormat='{}{0:F1}x'}" />
                </Grid>
                <Slider Minimum="0" Maximum="3"
                        Value="{Binding JitterExaggeration, Mode=TwoWay}" />
                <TextBlock Text="How much the live trace exaggerates beat-to-beat variability. 1.0x is the default; 0 flattens it."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Lobe thickness" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding LobeThickness, StringFormat='{}{0:F1}x'}" />
                </Grid>
                <Slider Minimum="0.5" Maximum="3"
                        Value="{Binding LobeThickness, Mode=TwoWay}" />
                <TextBlock Text="Stroke thickness of the live trace. 1.0x is the default; higher = bolder lobes."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Outline resolution" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding LobeSegments, StringFormat='{}{0} pts'}" />
                </Grid>
                <Slider Minimum="24" Maximum="256"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding LobeSegments, Mode=TwoWay}" />
                <TextBlock Text="How finely the figure-8 outline is sampled. Higher = smoother curve; lower = more faceted. Default 96."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Arousal histogram buckets" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding FieldIndexBuckets, StringFormat='{}{0}'}" />
                </Grid>
                <Slider Minimum="6" Maximum="64"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding FieldIndexBuckets, Mode=TwoWay}" />
                <TextBlock Text="Bucket resolution of the arousal-index histogram. Higher = finer detail; default 24."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Vagal-tone histogram buckets" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding FieldVagalBuckets, StringFormat='{}{0}'}" />
                </Grid>
                <Slider Minimum="6" Maximum="64"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding FieldVagalBuckets, Mode=TwoWay}" />
                <TextBlock Text="Bucket resolution of the vagal-tone histogram. Higher = finer detail; default 16."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Recovery arrow speed" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RecoveryArrowSpeed, StringFormat='{}{0:F1}x'}" />
                </Grid>
                <Slider Minimum="0.1" Maximum="3"
                        Value="{Binding RecoveryArrowSpeed, Mode=TwoWay}" />
                <TextBlock Text="How fast the recovery arrows pulse inward toward the centre during a Warning/Alert. 0.7x is the default; lower drifts in slowly, higher pulses in faster."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Recovery arrows" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RecoveryArrowCount, StringFormat='{}{0}'}" />
                </Grid>
                <Slider Minimum="1" Maximum="6"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding RecoveryArrowCount, Mode=TwoWay}" />
                <TextBlock Text="How many arrows ride the inward-pulling recovery train. Default 3."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Lobe opacity" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding LobeOpacityPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="0" Maximum="100"
                        Value="{Binding LobeOpacityPercent, Mode=TwoWay}" />
                <TextBlock Text="Opacity of the live-trace lobes. They glow additively and bloom where strokes overlap, so lower this if they saturate. Default 60%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Trail opacity" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding TrailOpacityPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="0" Maximum="100"
                        Value="{Binding TrailOpacityPercent, Mode=TwoWay}" />
                <TextBlock Text="Opacity of the comet trail. It glows additively where the tail overlaps itself and the marker. Default 70%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Histogram opacity" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding HistogramOpacityPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="0" Maximum="100"
                        Value="{Binding HistogramOpacityPercent, Mode=TwoWay}" />
                <TextBlock Text="Opacity of the arousal and vagal-tone histogram bars. Default 60%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Heatmap opacity" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding HeatmapOpacityPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="0" Maximum="100"
                        Value="{Binding HeatmapOpacityPercent, Mode=TwoWay}" />
                <TextBlock Text="Overall opacity of the dwell heatmap — where regulation has settled over the window. 0 hides it; default 35%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Peak crosshair" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding HeatmapPeakOpacityPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="0" Maximum="100"
                        Value="{Binding HeatmapPeakOpacityPercent, Mode=TwoWay}" />
                <TextBlock Text="Opacity of the crosshair pinning the busiest dwell bucket. 0 hides it; default 70%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Dwell region" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding HeatmapRegionOpacityPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="0" Maximum="100"
                        Value="{Binding HeatmapRegionOpacityPercent, Mode=TwoWay}" />
                <TextBlock Text="Opacity of the dashed box framing the high-concentration dwell region. 0 hides it; default 55%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Region threshold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding HeatmapRegionThresholdPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="0" Maximum="100"
                        Value="{Binding HeatmapRegionThresholdPercent, Mode=TwoWay}" />
                <TextBlock Text="How busy a bucket must be — as a share of the peak — to sit inside the dashed region. Default 50%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Heatmap window" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RegulationHeatmapLength, StringFormat='{}{0} pts'}" />
                </Grid>
                <Slider Minimum="60" Maximum="518400"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding RegulationHeatmapLength, Mode=TwoWay}" />
                <TextBlock Text="How many recent readings the dwell heatmap accumulates over (≈1 h at 720, up to ≈30 days). Default 720."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <TextBlock Text="Blend modes" FontWeight="SemiBold" Margin="0,8,0,0" />
                <TextBlock Text="Checked = additive glow bloom; unchecked = flat alpha compositing."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
                <CheckBox Content="LF/HF halo glows additively"
                          IsChecked="{Binding LfHfHaloAdditive, Mode=TwoWay}" />
                <CheckBox Content="Lobes glow additively"
                          IsChecked="{Binding LobesAdditive, Mode=TwoWay}" />
                <CheckBox Content="Trail glows additively"
                          IsChecked="{Binding TrailAdditive, Mode=TwoWay}" />
                <CheckBox Content="Heatmap glows additively"
                          IsChecked="{Binding HeatmapAdditive, Mode=TwoWay}" />
                <CheckBox Content="Marker halo glows additively"
                          IsChecked="{Binding MarkerHaloAdditive, Mode=TwoWay}" />
                <CheckBox Content="Histogram glows additively"
                          IsChecked="{Binding HistogramAdditive, Mode=TwoWay}" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Refresh" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="HRV emit interval" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding HrvEmitIntervalSeconds, StringFormat='{}{0:F1} s'}" />
                </Grid>
                <Slider Minimum="0.5" Maximum="30"
                        Value="{Binding HrvEmitIntervalSeconds, Mode=TwoWay}" />
                <TextBlock Text="How often a new HRV sample is emitted. Lower = smoother live graphs but noisier metrics. Default 5 s."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="History window" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding SparklineWindowMinutes, StringFormat='{}{0} min'}" />
                </Grid>
                <Slider Minimum="1" Maximum="360"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Value="{Binding SparklineWindowMinutes, Mode=TwoWay}" />
                <TextBlock Text="How much history the Metrics charts show. Higher = longer trends; lower = recent detail. Default 60 min."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Sensitivity" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="RMSSD drop to warn" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RmssdWarningDropPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="10" Maximum="70"
                        Value="{Binding RmssdWarningDropPercent, Mode=TwoWay}" />
                <TextBlock Text="RMSSD drop below baseline that raises a Warning. Lower = warns more readily. Default 30%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="HR rise to warn" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding HrWarningRisePercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="5" Maximum="50"
                        Value="{Binding HrWarningRisePercent, Mode=TwoWay}" />
                <TextBlock Text="HR rise above baseline that raises a Warning. Lower = warns more readily. Default 15%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="RMSSD drop to alert" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding RmssdAlertingDropPercent, StringFormat='{}{0:F0}%'}" />
                </Grid>
                <Slider Minimum="5" Maximum="95"
                        Value="{Binding RmssdAlertingDropPercent, Mode=TwoWay}" />
                <TextBlock Text="RMSSD drop that escalates to an Alert. Lower = escalates more readily. Default 50%."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Warning hold" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding WarningHoldSeconds, StringFormat='{}{0:F0} s'}" />
                </Grid>
                <Slider Minimum="5" Maximum="300"
                        Value="{Binding WarningHoldSeconds, Mode=TwoWay}" />
                <TextBlock Text="How long warning conditions must hold before the state advances. Default 30 s."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Alert escalation" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding AlertingEscalationSeconds, StringFormat='{}{0:F0} s'}" />
                </Grid>
                <Slider Minimum="10" Maximum="600"
                        Value="{Binding AlertingEscalationSeconds, Mode=TwoWay}" />
                <TextBlock Text="How long a Warning must persist before escalating to Alerting. Default 60 s."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />

                <Grid ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0" Text="Cooldown" />
                    <TextBlock Grid.Column="1"
                               Text="{Binding CooldownMinutes, StringFormat='{}{0:F0} min'}" />
                </Grid>
                <Slider Minimum="1" Maximum="60"
                        Value="{Binding CooldownMinutes, Mode=TwoWay}" />
                <TextBlock Text="Quiet period after an alert before another can fire. Default 10 min."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Pause" FontWeight="SemiBold" />
                <TextBlock Text="{Binding PausedUntilLabel}" Foreground="#8A8F98" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="Pause 1 hour" Command="{Binding PauseOneHourCommand}" />
                    <Button Content="Resume" Command="{Binding ResumeCommand}" />
                </StackPanel>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Apple Health" FontWeight="SemiBold" />
                <TextBlock Text="Optional — warms the baseline from your past 24 h of heart rate, and saves your data so you own it and can share it with a clinician."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
                <Button Content="Connect Apple Health"
                        Command="{Binding RequestHealthKitCommand}" />
                <CheckBox Content="Record heart rate, HRV &amp; beat-to-beat data"
                          IsChecked="{Binding RecordToHealth, Mode=TwoWay}" />
                <TextBlock Text="Writes downsampled heart rate, HRV, and the raw beat-to-beat series while monitoring."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
                <CheckBox Content="Save episodes to Apple Health"
                          IsChecked="{Binding WriteEpisodesToHealthKit, Mode=TwoWay}" />
                <TextBlock Text="Records each episode as a Mind &amp; Body entry you can review or share."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
                <Button Content="Revoke health access"
                        Command="{Binding RevokeHealthCommand}" />
                <TextBlock Text="Stops all reading and writing, and opens Health so you can revoke the system permission."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Data" FontWeight="SemiBold" />
                <TextBlock Text="Export your recorded history as a database file."
                           FontSize="12" Foreground="#8A8F98" TextWrapping="Wrap" />
                <Button Content="Export database"
                        Command="{Binding ExportDatabaseCommand}" />
            </StackPanel>

            <TextBlock Text="MeltdownMonitor is informational only. Not a medical device."
                       Foreground="#8A8F98"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,8,0,0" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
