<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MeltdownMonitor.Mobile.ViewModels"
             xmlns:ctl="clr-namespace:MeltdownMonitor.Mobile.Controls"
             xmlns:conv="clr-namespace:MeltdownMonitor.Mobile.Converters"
             x:Class="MeltdownMonitor.Mobile.Views.NowView"
             x:DataType="vm:NowViewModel">
    <Grid>
        <!-- Card / pill / metrics group sits at the top; a flexible spacer
             absorbs the remaining height so the field card sizes to its
             content (no ballooning + dead band) and the action buttons settle
             at the bottom of the screen regardless of phone height. -->
        <Grid RowDefinitions="Auto,Auto,Auto,*,Auto,Auto" Margin="20">

            <Border Grid.Row="0"
                    CornerRadius="12"
                    Background="#101418"
                    Padding="12">
                <Grid RowDefinitions="Auto,Auto,Auto">
                    <!-- The figure-8 is size-capped relative to its width, so a tall
                         star-sized slot just pads it with dead space. A definite,
                         phone-tuned height keeps the lobes filling the card with the
                         axis histograms and caption tucked right beneath them. -->
                    <ctl:RegulationField Grid.Row="0"
                                         Height="280"
                                         Reading="{Binding Reading}"
                                         Trail="{Binding RegulationTrail}"
                                         HeartRate="{Binding HeartRate}"
                                         StateColor="{Binding RegulationStateColor}"
                                         Dynamics="{Binding Dynamics}"
                                         Recovery="{Binding Recovery}"
                                         JitterExaggeration="{Binding JitterExaggeration}"
                                         LobeThickness="{Binding LobeThickness}"
                                         LobeSegments="{Binding LobeSegments}"
                                         IndexBuckets="{Binding IndexBuckets}"
                                         VagalBuckets="{Binding VagalBuckets}"
                                         RecoveryArrowSpeed="{Binding RecoveryArrowSpeed}"
                                         RecoveryArrowCount="{Binding RecoveryArrowCount}"
                                         Hypoarousal="{Binding Reading.Hypoarousal}"
                                         HypoarousalDynamics="{Binding HypoarousalDynamics}"
                                         Rr="{Binding RecentRr}"
                                         RrBeatsAppended="{Binding RrBeatsAppended}"
                                         DwellTrail="{Binding DwellTrail}"
                                         LobeOpacity="{Binding LobeOpacity}"
                                         TrailOpacity="{Binding TrailOpacity}"
                                         HistogramOpacity="{Binding HistogramOpacity}"
                                         HeatmapOpacity="{Binding HeatmapOpacity}"
                                         HeatmapPeakOpacity="{Binding HeatmapPeakOpacity}"
                                         HeatmapRegionOpacity="{Binding HeatmapRegionOpacity}"
                                         HeatmapRegionThreshold="{Binding HeatmapRegionThreshold}"
                                         UseLfHfCorroboration="{Binding UseLfHfCorroboration}"
                                         LfHfHaloAdditive="{Binding LfHfHaloAdditive}"
                                         LobesAdditive="{Binding LobesAdditive}"
                                         TrailAdditive="{Binding TrailAdditive}"
                                         HeatmapAdditive="{Binding HeatmapAdditive}"
                                         MarkerHaloAdditive="{Binding MarkerHaloAdditive}"
                                         HistogramAdditive="{Binding HistogramAdditive}" />
                    <ctl:Sparkline Grid.Row="1"
                                   Height="48"
                                   Margin="0,8,0,0"
                                   Values="{Binding RmssdHistory}"
                                   BaselineValues="{Binding BaselineHistory}"
                                   Timestamps="{Binding RmssdTimestamps}"
                                   WindowSeconds="60"
                                   LineThickness="2" />
                    <TextBlock Grid.Row="2"
                               Text="Regulation field · RMSSD vs baseline"
                               Foreground="#8A8F98"
                               FontSize="12"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Margin="0,20,0,0"
                    CornerRadius="20"
                    Padding="16,10"
                    HorizontalAlignment="Center"
                    Background="{Binding StateBrush}">
                <TextBlock Text="{Binding StateLabel}"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold" />
            </Border>

            <StackPanel Grid.Row="2"
                        Margin="0,16,0,0"
                        Orientation="Vertical"
                        HorizontalAlignment="Center"
                        Spacing="4">
                <TextBlock Text="{Binding HeartRateText}"
                           FontSize="36"
                           FontWeight="Light"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding RmssdText}" HorizontalAlignment="Center" />
                <TextBlock Text="{Binding BaselineText}"
                           Foreground="#8A8F98"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding BatteryText}"
                           Foreground="#8A8F98"
                           FontSize="12"
                           HorizontalAlignment="Center" />
                <!-- Low-arousal collapse reads as the cool/calm side of the field; this badge keeps it
                     from being mistaken for regulation (audit A(b)). Slate (#5D6A9E) matches the
                     shutdown zone fill in RegulationField and the desktop head's collapse cues. -->
                <TextBlock Text="Low arousal · shutdown — not calm rest"
                           Foreground="#5D6A9E"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding IsShutdown}" />
                <TextBlock Text="Baseline calibrated cold — readings may be off if you started activated"
                           Foreground="#8A8F98"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding IsColdCalibrated}" />
                <!-- Hidden via opacity, not IsVisible, so the bar keeps its layout
                     footprint and its neighbours don't jump when the trend appears. -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Opacity="{Binding IsTrendVisible, Converter={x:Static conv:BoolToOpacityConverter.Instance}}">
                    <TextBlock Text="{Binding TrendLabel}"
                               Foreground="#CAD3F5"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding VelocityText}"
                               Foreground="#8A8F98"
                               FontSize="13" />
                    <ProgressBar Width="60"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="{Binding NormalizedSpeed}"
                                 VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="8"
                            Opacity="{Binding IsRecoveryVisible, Converter={x:Static conv:BoolToOpacityConverter.Instance}}">
                    <TextBlock Text="{Binding RecoveryText}"
                               Foreground="#A6DA95"
                               FontSize="13"
                               FontWeight="SemiBold" />
                    <ProgressBar Width="60"
                                 Minimum="0"
                                 Maximum="1"
                                 Value="{Binding RecoveryFraction}"
                                 VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock Text="Sensor contact lost — readings paused"
                           IsVisible="{Binding IsContactLost}"
                           Foreground="#E5C07B"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding TimeSinceStateChange}"
                           Foreground="#8A8F98"
                           FontSize="12"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding DeviceInfoText}"
                           IsVisible="{Binding HasDeviceInfo}"
                           Foreground="#5A6068"
                           FontSize="11"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <Button Grid.Row="4"
                    Margin="0,16,0,0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="16,12"
                    Content="How are you feeling?"
                    Command="{Binding OpenAnnotationCommand}" />

            <Button Grid.Row="5"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Padding="16,12"
                    Content="{Binding ConnectionLabel}"
                    Command="{Binding ToggleConnectionCommand}" />
        </Grid>

        <!-- Self check-in sheet (design doc §5): a dimmed backdrop with the
             same four labels the desktop annotation dialog offers, plus an
             optional note. Tapping a label records it and dismisses. -->
        <Border Background="#CC000000"
                IsVisible="{Binding IsAnnotationSheetOpen}">
            <Panel>
                <!-- Tap the dimmed scrim outside the sheet to dismiss it — the
                     standard bottom-sheet gesture. The sheet Border below is opaque
                     and sits on top, so taps on it don't reach this catcher. The
                     pointer-state setters keep the catcher fully transparent (no
                     button chrome flashing over the scrim on tap). -->
                <Button Command="{Binding CancelAnnotationCommand}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        CornerRadius="0">
                    <Button.Styles>
                        <Style Selector="Button:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                        <Style Selector="Button:pressed /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                        </Style>
                    </Button.Styles>
                </Button>

                <Border VerticalAlignment="Bottom"
                    Background="#1A1F25"
                    CornerRadius="16,16,0,0"
                    Padding="20,24">
                <StackPanel Spacing="16">
                    <TextBlock Text="How are you feeling?"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center" />

                    <ItemsControl ItemsSource="{Binding AnnotationLabels}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center"
                                            Spacing="8" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}"
                                        MinWidth="72"
                                        Padding="12,10"
                                        HorizontalContentAlignment="Center"
                                        Command="{Binding $parent[ItemsControl].((vm:NowViewModel)DataContext).RecordAnnotationCommand}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBox Text="{Binding AnnotationNotes}"
                             PlaceholderText="Optional note…"
                             AcceptsReturn="False" />

                    <Button Content="Cancel"
                            HorizontalAlignment="Center"
                            Command="{Binding CancelAnnotationCommand}" />
                </StackPanel>
                </Border>
            </Panel>
        </Border>
    </Grid>
</UserControl>
