<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MeltdownMonitor.Mobile.Views.NowView">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
        <TextBlock Text="Now" FontSize="24" HorizontalAlignment="Center" />
        <TextBlock Text="Live chart goes here." HorizontalAlignment="Center" />
    </StackPanel>
</UserControl>
